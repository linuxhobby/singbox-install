{
  "type": "vless",
  "tag": "vless-reality-xhttp",
  "listen": "0.0.0.0",
  "listen_port": 443,
  "users": [
    {
      "uuid": "PLACEHOLDER_UUID"
    }
  ],
  "tls": {
    "enabled": true,
    "reality": {
      "enabled": true,
      "handshake": {
        "server": "www.bing.com",
        "server_port": 443
      },
      "private_key": "PLACEHOLDER_SK",
      "short_id": ["PLACEHOLDER_SID"]
    }
  },
  "transport": {
    "type": "xhttp"
  }
}