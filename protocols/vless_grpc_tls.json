{
  "type": "vless",
  "tag": "vless-grpc-tls",
  "listen": "0.0.0.0",
  "listen_port": 443,
  "users": [
    {
      "uuid": "PLACEHOLDER_UUID"
    }
  ],
  "tls": {
    "enabled": true,
    "server_name": "PLACEHOLDER_DOMAIN"
  },
  "transport": {
    "type": "grpc",
    "service_name": "grpc"
  }
}